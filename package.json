{
  "name": "memecoin-trader",
  "version": "0.1.0",
  "private": true,
  "description": "Conservative Solana memecoin screening and trade planning pipeline",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "db:init": "tsx src/scripts/init-database.ts",
    "screen:token": "tsx src/scripts/screen-token.ts",
    "plan:trade": "tsx src/scripts/build-trade-plan.ts",
    "approve:plan": "tsx src/scripts/approve-plan.ts",
    "execute:trade": "tsx src/scripts/execute-trade.ts",
    "trade:execute": "tsx src/scripts/execute-trade.ts",
    "monitor:positions": "tsx src/scripts/monitor-positions.ts",
    "position:manager": "tsx src/scripts/position-manager-bootstrap.ts",
    "whale:tracker": "tsx src/scripts/whale-tracker-bootstrap.ts",
    "whale:scout": "tsx src/scripts/whale-scout-bootstrap.ts",
    "dashboard:legacy": "tsx src/scripts/dashboard-bootstrap.ts",
    "dashboard:web:dev": "npm --prefix web run dev",
    "dashboard:web:build": "npm --prefix web run build",
    "dashboard:web:start": "npm --prefix web run start",
    "dashboard": "npm run dashboard:web:build && npm run dashboard:web:start",
    "profit:report": "tsx src/scripts/profit-report.ts",
    "audit:storage": "tsx src/scripts/audit-storage.ts"
  },
  "dependencies": {
    "@pump-fun/pump-sdk": "^1.32.0",
    "@pump-fun/pump-swap-sdk": "^1.14.1",
    "@raydium-io/raydium-sdk": "^1.3.1-beta.58",
    "@solana/web3.js": "^1.98.4",
    "better-sqlite3": "^12.8.0",
    "bs58": "^6.0.0",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-basic-auth": "^1.2.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/bn.js": "^5.2.0",
    "@types/express": "^5.0.6",
    "@types/node": "^24.5.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2"
  }
}

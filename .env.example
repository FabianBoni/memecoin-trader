# Runtime
NODE_ENV=production
LOG_LEVEL=info
DRY_RUN=true
REQUIRE_EXPLICIT_GO=true
RPC_DEBUG_USE_CURL=false

# Storage
# On servers, prefer absolute paths so PM2/systemd cwd changes do not move your state unexpectedly.
STORE_PATH=./data
DATABASE_PATH=./data/memecoin-trader.sqlite
DATABASE_AUTO_MIGRATE=true
DATABASE_BUSY_TIMEOUT_MS=5000

# RPC / market data
HELIUS_API_KEY=
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your-api-key
SOLANA_RPC_URL=
FALLBACK_MAINNET_RPC_URL=
BIRDEYE_API_KEY=
DEXSCREENER_BASE_URL=https://api.dexscreener.com/latest

# Wallet / execution
SOLANA_WALLET_PUBLIC_KEY=
SOLANA_WALLET_PRIVATE_KEY=
SOLANA_PRIVATE_KEY=
WALLET_ADDRESS=
MIN_SOL_RESERVE=0.05

# Program IDs / liquidity metadata
RAYDIUM_AMM_PROGRAM_ID=
PUMPFUN_PROGRAM_ID=
PUMPFUN_AMM_PROGRAM_ID=
LP_LOCKER_ADDRESSES=

# Jito
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf
JITO_AUTH_KEY=
JITO_BUNDLE_TIP_LAMPORTS=1000
MAX_PRIORITY_FEE_SOL=0.01

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_DEDUPE_MS=60000
TELEGRAM_BURST_WINDOW_MS=300000
TELEGRAM_MAX_PER_WINDOW=8

# Execution / routing
MAX_JUPITER_BUY_SLIPPAGE_BPS=250
MAX_JUPITER_VOLATILE_BUY_SLIPPAGE_BPS=500
MAX_JUPITER_SELL_SLIPPAGE_BPS=500
MAX_JUPITER_PRICE_IMPACT_PCT=15
MAX_JUPITER_ROUTE_HOPS=2
AUTO_BUY_AMOUNT_SOL=0.3
MIN_LIVE_TRADE_SIZE_SOL=0.03

# Risk
RISK_PER_TRADE_PCT=1.5
MAX_CAPITAL_AT_RISK_PCT=6
ESTIMATED_ROUND_TRIP_COST_BPS=350
DEFAULT_MAX_POSITION_SOL=0.3
DEFAULT_MAX_OPEN_EXPOSURE_SOL=0.5
DEFAULT_MAX_SLIPPAGE_BPS=250
DEFAULT_STOP_LOSS_PCT=30
DEFAULT_TAKE_PROFIT_PCT=100
DEFAULT_TAKE_PROFIT_SELL_FRACTION=0.5
RUNNER_STOP_FLOOR_PCT=10
TRAILING_ARM_PCT=25
TRAILING_DISTANCE_PCT=15

# Paper / live evaluation
PAPER_PROMOTION_MIN_TRADES=8
PAPER_PROMOTION_MIN_WIN_RATE_PCT=60
PAPER_PROMOTION_MIN_AVG_PNL_PCT=5
PAPER_PROMOTION_MIN_MEDIAN_PNL_PCT=2
LIVE_ELIMINATION_MIN_TRADES=5
LIVE_ELIMINATION_MAX_LOSS_STREAK=4
LIVE_ELIMINATION_MAX_AVG_PNL_PCT=-8

# Entry filters
MIN_ENTRY_LIQUIDITY_USD=25000
MIN_WHALE_BUY_SIZE_SOL=0.5
MAX_ENTRY_PRICE_EXTENSION_PCT=12
MIN_EXPECTED_NET_PROFIT_PCT=18
MIN_REWARD_RISK_RATIO=1.35
WHALE_SELL_TRIM_IGNORE_FRACTION_PCT=25
WHALE_PANIC_SELL_MIN_FRACTION_PCT=70
TRACKER_SIGNAL_CLUSTER_WINDOW_MS=180000
TRACKER_SIGNAL_CLUSTER_MIN_WALLETS=2
TRACKER_SIGNAL_CLUSTER_MIN_PREMIUM_WALLETS=1
TRACKER_SIGNAL_CLUSTER_MIN_INSIDER_WALLETS=1
TRACKER_SIGNAL_MIN_BUY_USD=500

# Scout seed sourcing
SCOUT_BOOST_SCAN_LIMIT=12
SCOUT_BOOST_TOKEN_LIMIT=5
SCOUT_MARKET_TOKEN_LIMIT=12
SCOUT_SEED_CHECK_LIMIT=10
SCOUT_MIN_SEED_VOLUME_USD=100000
SCOUT_MIN_SEED_LIQUIDITY_USD=25000
SCOUT_MIN_SEED_TX_COUNT=100
SCOUT_MIN_SEED_AVG_TRADE_USD=200
SCOUT_MIN_SEED_TRADER_VOLUME_USD=1000

# Scout RPC / wallet evaluation
SCOUT_PARSED_TX_BATCH_SIZE=12
SCOUT_TOKEN_SIGNATURE_BATCH_LIMIT=50
SCOUT_TOKEN_SIGNATURE_LIMIT=8
SCOUT_TOKEN_SIGNATURE_SCAN_CAP=150
SCOUT_WHALE_SIGNATURE_LIMIT=20
SCOUT_WHALE_DEEP_SIGNATURE_LIMIT=120
SCOUT_WHALE_EXTENDED_SIGNATURE_LIMIT=300
SCOUT_WHALE_LOOKBACK_HOURS=24
SCOUT_DEEP_SCAN_TRIGGER_VOLUME_USD=2500
SCOUT_MIN_WHALE_VOLUME_USD=25000
SCOUT_MIN_WHALE_TX_COUNT=6
SCOUT_MIN_WHALE_DISTINCT_TOKENS=2
SCOUT_RPC_MIN_INTERVAL_MS=500
SCOUT_RATE_LIMIT_COOLDOWN_MS=4000
SCOUT_REJECT_COOLDOWN_MINUTES=180

# Position-manager overrides
TAKE_PROFIT_PCT_MONITOR=50
STOP_LOSS_PCT_MONITOR=-20